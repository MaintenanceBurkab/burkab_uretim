async function durusKaydet(){
  const bolum   =document.getElementById('durusBolum').value;
  const makine  =document.getElementById('durusMakine')?.value?.trim();
  const bildiren=document.getElementById('durusBildiren').value.trim();
  const neden   =document.getElementById('durusNeden').value;
  const etkisi  =document.getElementById('durusEtkisi').value;
  const sureDk  =document.getElementById('durusSureDk').value;
  const aciklama=document.getElementById('durusAciklama').value.trim();
  const sorumluB=document.getElementById('durusSorumluBolum').value;

  if(!bolum)   {showToast('❗ Bölüm seçiniz!','err');return;}
  if(!makine)  {showToast('❗ Makine/ekipman giriniz!','err');return;}
  if(!bildiren){showToast('❗ Bildiren kişi giriniz!','err');return;}
  if(!neden)   {showToast('❗ Duruş nedeni seçiniz!','err');return;}
  if(!etkisi)  {showToast('❗ Duruş etkisi seçiniz!','err');return;}
  if(!sureDk)  {showToast('❗ Duruş süresi giriniz!','err');return;}
  if(!aciklama){showToast('❗ Açıklama giriniz!','err');return;}
  if(!sorumluB){showToast('❗ Sorumlu bölüm seçiniz!','err');return;}

  const btn=document.getElementById('durusKaydetBtn');
  btn.disabled=true;btn.textContent='⏳ Kaydediliyor...';
  const simdi=new Date();
  const tarih=simdi.toISOString().split('T')[0];
  const saat=String(simdi.getHours()).padStart(2,'0')+':'+String(simdi.getMinutes()).padStart(2,'0');
  let hesaplanan=parseInt(sureDk)||0;
  if(etkisi==='KISMİ DURUŞ') hesaplanan=Math.round(hesaplanan*0.7);
  else if(etkisi==='DURUŞ YOK') hesaplanan=0;
  const formNo=durusFormNoUret();
  const kayit={id:simdi.getTime(),formNo,tarih,saat,bolum,makine,bildiren,neden,etkisi,sureDk:parseInt(sureDk)||0,hesaplanan,projeNo:document.getElementById('durusProjeNo').value,sorumluBolum:sorumluB,sorumluKisi:document.getElementById('durusSorumluKisi').value,kokNeden:document.getElementById('durusKokNeden').value.trim(),aciklama,yapilan:document.getElementById('durusYapilan').value.trim(),kayitZamani:simdi.toLocaleString('tr-TR')};
 const liste=duruslariYukle();liste.unshift(kayit);duruslariKaydet(liste);

  // ✅ GS: Duruslar sayfasına gönder
  saveDurusKayitGS(kayit);

  document.getElementById('durusFormNo').textContent=formNo;
  const basari=document.getElementById('durusBasari');basari.style.display='block';
  setTimeout(()=>basari.style.display='none',4000);
  ['durusBolum','durusEtkisi','durusSureDk','durusProjeNo','durusSorumluBolum','durusKokNeden','durusAciklama','durusYapilan'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('durusMakineWrapper').innerHTML=`<input type="text" id="durusMakine" placeholder="Önce bölüm seçiniz" readonly style="background:#f0f0ec;cursor:not-allowed;color:#aaa">`;
  document.getElementById('durusSorumluKisi').innerHTML='<option value="">— Önce bölüm seçiniz —</option>';
  document.getElementById('durusHesaplanan').value='';document.getElementById('durusHesapAciklama').textContent='';
  document.getElementById('durusNeden').value='';
  document.querySelectorAll('.durus-neden-btn').forEach(b=>{b.classList.remove('active');b.style.borderColor='#d0d0c0';b.style.background='var(--bg)';b.style.boxShadow='';if(b.querySelector('span:last-child'))b.querySelector('span:last-child').style.color='var(--muted)';});
  if(currentUser) document.getElementById('durusBildiren').value=currentUser.name;
  durusSaatGuncelle();
  renderDurusGecmis();durusKpiGuncelle();
  showToast('✅ Duruş kaydedildi! ('+formNo+')','ok');
  btn.disabled=false;btn.textContent='⏱️ DURUŞ KAYDET';
}

function renderDurusGecmis(){
  const liste=document.getElementById('durusGecmisListe');
  if(!liste) return;
  const filtreBolum=document.getElementById('durusFiltreBolum')?.value||'';
  const filtreNeden=document.getElementById('durusFiltreNeden')?.value||'';
  let kayitlar=duruslariYukle();
  if(filtreBolum) kayitlar=kayitlar.filter(k=>k.bolum===filtreBolum);
  if(filtreNeden) kayitlar=kayitlar.filter(k=>k.neden===filtreNeden);
  if(!kayitlar.length){liste.innerHTML='<div class="empty">Kayıt bulunamadı.</div>';return;}
  const nedenRenk={'MEKANİK ARIZA':'#d32f2f','ELEKTRİK ARIZA':'#e65100','ELEKTRONİK ARIZA':'#6a1b9a','MALZEME EKSİKLİĞİ':'#0277bd','KALIP DEĞİŞİMİ':'#00875a','PLANLI BAKIM':'#558b2f','KALİTE SORUNU':'#f57f17','PERSONEL EKSİKLİĞİ':'#4527a0','DİĞER':'#546e7a'};
  const etkiBadge={'TAM DURUŞ':'b-red','KISMİ DURUŞ':'b-orange','PLANLI DURUŞ':'b-blue','DURUŞ YOK':'b-gray'};
  liste.innerHTML=kayitlar.map(k=>{
    const renk=nedenRenk[k.neden]||'#e65100';
    const badge=etkiBadge[k.etkisi]||'b-gray';
    return `<div style="background:#fff;border:1.5px solid #e0ddd5;border-radius:10px;padding:14px 16px;margin-bottom:10px;border-left:5px solid ${renk};transition:box-shadow .15s">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;flex-wrap:wrap;margin-bottom:8px">
        <div>
          <span style="font-size:14px;font-weight:800;color:${renk}">${k.neden}</span>
          <span style="font-size:12px;color:#888;margin-left:10px">${k.formNo}</span>
        </div>
        <div style="display:flex;gap:6px;align-items:center">
          <span class="badge ${badge}">${k.etkisi}</span>
          <span class="badge b-purple">${k.hesaplanan} dk</span>
          <button onclick="durusSil(${k.id})" class="btn-sm red" style="padding:3px 8px;font-size:11px">Sil</button>
        </div>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:6px 14px;font-size:12px;color:#666;margin-bottom:6px">
        <span>🏭 ${k.bolum}</span><span>⚙️ ${k.makine}</span><span>👤 ${k.bildiren}</span>
        ${k.projeNo?`<span>📋 ${k.projeNo}</span>`:''}
        ${k.sorumluBolum?`<span>🎯 ${k.sorumluBolum}${k.sorumluKisi?' / '+k.sorumluKisi:''}</span>`:''}
        <span>🕐 ${k.tarih} ${k.saat}</span>
      </div>
      ${k.aciklama?`<div style="font-size:13px;color:#333;font-style:italic;background:#fafaf8;border-radius:6px;padding:8px 10px;margin-top:6px">"${k.aciklama}"</div>`:''}
      ${k.kaynakFormNo?`<div style="font-size:11px;color:#0277bd;margin-top:4px;background:#e3f2fd;border-radius:4px;padding:3px 8px;display:inline-block">🔗 Bakım Talebi: ${k.kaynakFormNo}</div>`:''}
      ${k.yapilan?`<div style="font-size:12px;color:#555;margin-top:6px;padding:6px 10px;background:#e8f5e9;border-radius:5px">🔧 ${k.yapilan}</div>`:''}
      <div style="font-size:11px;color:#bbb;margin-top:6px;font-family:'IBM Plex Mono',monospace">${k.kayitZamani}</div>
    </div>`;
  }).join('');
}

function durusSil(id){
  if(!confirm('Bu duruş kaydını silmek istiyor musunuz?')) return;
  duruslariKaydet(duruslariYukle().filter(k=>k.id!==id));
  renderDurusGecmis();durusKpiGuncelle();showToast('🗑️ Duruş kaydı silindi','ok');
}

function durusTumunuSil(){
  if(!confirm('Tüm duruş kayıtları silinecek. Emin misiniz?')) return;
  duruslariKaydet([]);renderDurusGecmis();durusKpiGuncelle();showToast('🗑️ Tüm duruş kayıtları silindi','ok');
}

function durusKpiGuncelle(){
  const liste=duruslariYukle();
  const today=new Date().toISOString().split('T')[0];
  const bugunDurus=liste.filter(k=>k.tarih===today);
  const toplSure=liste.reduce((a,k)=>a+(k.hesaplanan||0),0);
  const ort=liste.length?Math.round(toplSure/liste.length):0;
  const bakimKaynakli=liste.filter(k=>k.kaynakFormNo).length;
  const el=(id,v)=>{const e=document.getElementById(id);if(e)e.textContent=v;};
  el('dkToplam',liste.length);el('dkBugün',bugunDurus.length);
  el('dkToplSure',toplSure+' dk');el('dkOrtSure',ort+' dk');
  const bEl=document.getElementById('dkBakimKaynakli');if(bEl)bEl.textContent=bakimKaynakli;
  const talepler=taleplerYukle();
  const bekleyenler=talepler.filter(t=>t.durum!=='kapatildi'&&t.islem==='ARIZA KAYDI');
  const bandi=document.getElementById('bekleyenTalepBandi');
  const listeEl=document.getElementById('bekleyenTalepListesi');
  if(bandi&&listeEl){
    if(bekleyenler.length){
      bandi.style.display='block';
      listeEl.textContent=bekleyenler.slice(0,5).map(t=>`${t.formNo} (${t.bolum}·${t.makine})`).join(' · ')+(bekleyenler.length>5?` +${bekleyenler.length-5} daha`:'');
    } else bandi.style.display='none';
  }
}
